@model FinalProject.ViewModels.HomeIndexViewModel
@* Головна сторінка: пошук, список подій, кнопка Завантажити ще, блок найближчих подій. *@
@{
    ViewData["Title"] = "Головна";
    var userName = User.Identity?.Name ?? "User";
    var selectedCategoryId = Model.SelectedCategoryIds.FirstOrDefault();
}

<div class="ph-wrap">
    <header class="ph-topbar">
        <div class="ph-topbar-inner">
            <a class="ph-brand" asp-controller="Home" asp-action="Index">
                PodiiHub<span class="brand-dot"></span>
            </a>
            <nav class="ph-nav">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="ph-profile-menu">
                        <button type="button" class="ph-profile-pill">@userName</button>
                        <div class="ph-profile-dropdown">
                            <a asp-controller="Account" asp-action="Profile" class="ph-btn-ghost">Профіль</a>
                            @if (User.IsInRole("admin"))
                            {
                                <a asp-controller="Admin" asp-action="Index" class="ph-btn-ghost">Admin</a>
                            }
                            <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="ph-btn-ghost">Вийти</button>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <a class="ph-btn-ghost" asp-controller="Account" asp-action="Login">Увійти</a>
                }
            </nav>
        </div>
    </header>

    <div class="ph-shell">
        <section class="ph-hero">
            <h1>Події, які <em>хочеться</em> відвідати</h1>
            <p>Добірка актуальних конференцій, самітів і мітапів з технологій, продукту та бізнесу.</p>
        </section>

        <form class="ph-search-row" method="get" asp-controller="Home" asp-action="Index">
            <div class="ph-search-input-wrap">
                <input type="text" name="searching" value="@Model.SearchQuery" placeholder="Пошук подій за назвою..." />
            </div>
            <div class="ph-select-wrap">
                <select name="categoryIds" aria-label="Категорія">
                    <option value="">Усі категорії</option>
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category.Id" selected="@(selectedCategoryId == category.Id)">@category.Name</option>
                    }
                </select>
            </div>
            <div class="ph-select-wrap">
                <select name="sortBy" aria-label="Сортування">
                    <option value="date" selected="@(Model.SortBy == "date")">За датою</option>
                    <option value="title" selected="@(Model.SortBy == "title")">За назвою</option>
                    <option value="capacity" selected="@(Model.SortBy == "capacity")">За місцями</option>
                </select>
            </div>
            <div class="ph-search-actions">
                <button class="ph-btn-search" type="submit">Пошук</button>
                <button class="ph-btn-filter" type="button" id="openFiltersBtn">Фільтри</button>
            </div>
            <input type="hidden" name="onlyUpcoming" value="@Model.OnlyUpcoming.ToString().ToLowerInvariant()" />
        </form>

        <main class="ph-main">
            <p class="ph-section-label">Останні події</p>

            <div id="eventList" class="ph-event-list">
                @await Html.PartialAsync("~/Views/Shared/EventsChunk.cshtml", new FinalProject.ViewModels.EventsChunkViewModel
                {
                    Events = Model.Events,
                    NextSkip = Model.NextSkip,
                    HasMore = Model.HasMore
                })
            </div>

            @if (Model.HasMore)
            {
                <div class="ph-load-more-wrap">
                    <button id="loadMoreBtn"
                            type="button"
                            class="ph-load-more-btn"
                            data-skip="@Model.NextSkip"
                            data-take="@Model.Take"
                            data-searching="@Model.SearchQuery"
                            data-category-ids="@string.Join(",", Model.SelectedCategoryIds)"
                            data-sort-by="@Model.SortBy"
                            data-only-upcoming="@Model.OnlyUpcoming.ToString().ToLowerInvariant()">
                        Завантажити ще
                    </button>
                </div>
            }
            <div id="loadMoreSentinel" class="ph-load-more-sentinel" aria-hidden="true"></div>
        </main>

        <aside class="ph-sidebar">
            <div class="ph-sidebar-block">
                <p class="ph-sidebar-title">Найближчі події</p>
                <ul class="ph-sidebar-upcoming">
                    @foreach (var upcomingEvent in Model.UpcomingEvents)
                    {
                        <li>
                            <span class="sui-date">@upcomingEvent.StartAt.ToString("dd MMM yyyy")</span>
                            <a class="sui-name-link"
                               asp-controller="Home"
                               asp-action="Details"
                               asp-route-id="@upcomingEvent.Id">
                                <span class="sui-name">@upcomingEvent.Title</span>
                            </a>
                            <span class="sui-loc">@upcomingEvent.Location</span>
                        </li>
                    }
                </ul>
            </div>
        </aside>

        <footer class="ph-footer">
            <span>© 2026 PodiiHub</span>
            <span>Всі події України</span>
        </footer>
    </div>
</div>

<div id="filtersModal" class="ph-modal-backdrop" aria-hidden="true">
    <div class="ph-modal-card" role="dialog" aria-modal="true" aria-labelledby="filtersModalTitle">
        <div class="ph-modal-head">
            <div>
                <p class="ph-sidebar-title" id="filtersModalTitle">Фільтри</p>
                <p class="ph-sidebar-subtitle">Вибери кілька категорій, порядок сортування та часовий фільтр.</p>
            </div>
            <button type="button" class="ph-modal-close" id="closeFiltersBtn" aria-label="Закрити">×</button>
        </div>

        <form method="get" asp-controller="Home" asp-action="Index" class="ph-modal-form">
            <input type="hidden" name="searching" value="@Model.SearchQuery" />

            <div class="ph-modal-section">
                <span class="ph-modal-label">Категорії</span>
                <div class="ph-modal-choice-list ph-modal-choice-list-categories">
                    @foreach (var category in Model.Categories)
                    {
                        var isSelected = Model.SelectedCategoryIds.Contains(category.Id);
                        <label class="ph-modal-choice-chip @(isSelected ? "ph-modal-choice-chip-selected" : string.Empty)">
                            <input type="checkbox" name="categoryIds" value="@category.Id" @(isSelected ? "checked" : null) />
                            <span>@category.Name</span>
                        </label>
                    }
                </div>
            </div>

            <div class="ph-modal-section">
                <span class="ph-modal-label">Сортування</span>
                <div class="ph-modal-choice-list">
                    <label class="ph-modal-choice-chip @(Model.SortBy == "date" ? "ph-modal-choice-chip-selected" : string.Empty)">
                        <input type="radio" name="sortBy" value="date" @(Model.SortBy == "date" ? "checked" : null) />
                        <span>За датою</span>
                    </label>
                    <label class="ph-modal-choice-chip @(Model.SortBy == "title" ? "ph-modal-choice-chip-selected" : string.Empty)">
                        <input type="radio" name="sortBy" value="title" @(Model.SortBy == "title" ? "checked" : null) />
                        <span>За назвою</span>
                    </label>
                    <label class="ph-modal-choice-chip @(Model.SortBy == "capacity" ? "ph-modal-choice-chip-selected" : string.Empty)">
                        <input type="radio" name="sortBy" value="capacity" @(Model.SortBy == "capacity" ? "checked" : null) />
                        <span>За вільними місцями</span>
                    </label>
                </div>
            </div>

            <label class="ph-modal-checkbox">
                <input type="checkbox" name="onlyUpcoming" value="true" @(Model.OnlyUpcoming ? "checked" : null) />
                <span>Показувати лише майбутні події</span>
            </label>

            <div class="ph-modal-actions">
                <a asp-controller="Home"
                   asp-action="Index"
                   asp-route-searching="@Model.SearchQuery"
                   class="ph-sidebar-action ph-sidebar-action-ghost">Скинути</a>
                <button type="submit" class="ph-sidebar-action ph-sidebar-action-primary">Застосувати</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const loadMoreBtn = document.getElementById("loadMoreBtn");
            const eventList = document.getElementById("eventList");
            const modal = document.getElementById("filtersModal");
            const openFiltersBtn = document.getElementById("openFiltersBtn");
            const closeFiltersBtn = document.getElementById("closeFiltersBtn");

            if (openFiltersBtn && modal) {
                openFiltersBtn.addEventListener("click", function () {
                    modal.classList.add("is-open");
                    modal.setAttribute("aria-hidden", "false");
                    document.body.classList.add("ph-modal-open");
                });
            }

            if (closeFiltersBtn && modal) {
                closeFiltersBtn.addEventListener("click", function () {
                    modal.classList.remove("is-open");
                    modal.setAttribute("aria-hidden", "true");
                    document.body.classList.remove("ph-modal-open");
                });
            }

            if (modal) {
                modal.addEventListener("click", function (event) {
                    if (event.target === modal) {
                        modal.classList.remove("is-open");
                        modal.setAttribute("aria-hidden", "true");
                        document.body.classList.remove("ph-modal-open");
                    }
                });
            }

            document.addEventListener("keydown", function (event) {
                if (event.key === "Escape" && modal && modal.classList.contains("is-open")) {
                    modal.classList.remove("is-open");
                    modal.setAttribute("aria-hidden", "true");
                    document.body.classList.remove("ph-modal-open");
                }
            });

            if (loadMoreBtn && eventList) {
                let loading = false;

                loadMoreBtn.addEventListener("click", async function () {
                if (loading) return;
                loading = true;
                loadMoreBtn.disabled = true;
                loadMoreBtn.textContent = "Завантаження...";

                const skip = loadMoreBtn.dataset.skip || "0";
                const take = loadMoreBtn.dataset.take || "10";
                const searching = loadMoreBtn.dataset.searching || "";
                const categoryIds = (loadMoreBtn.dataset.categoryIds || "")
                    .split(",")
                    .map(function (value) { return value.trim(); })
                    .filter(function (value) { return value.length > 0; });
                const sortBy = loadMoreBtn.dataset.sortBy || "date";
                const onlyUpcoming = loadMoreBtn.dataset.onlyUpcoming || "false";
                const encodedSearching = encodeURIComponent(searching);
                const searchingQuery = searching ? `&searching=${encodedSearching}` : "";
                const categoryQuery = categoryIds
                    .map(function (value) { return `&categoryIds=${encodeURIComponent(value)}`; })
                    .join("");
                const sortByQuery = sortBy ? `&sortBy=${encodeURIComponent(sortBy)}` : "";
                const onlyUpcomingQuery = onlyUpcoming === "true" ? "&onlyUpcoming=true" : "";

                try {
                    const response = await fetch(`/Home/LoadMore?skip=${skip}&take=${take}${searchingQuery}${categoryQuery}${sortByQuery}${onlyUpcomingQuery}`, { method: "GET" });
                    if (!response.ok) throw new Error("Load failed");

                    const html = await response.text();
                    const temp = document.createElement("div");
                    temp.innerHTML = html;

                    const chunkMeta = temp.querySelector(".ph-chunk-meta");
                    temp.querySelectorAll(".ph-event-row").forEach(function (card) {
                        eventList.appendChild(card);
                    });

                    if (!chunkMeta) { loadMoreBtn.remove(); return; }

                    const hasMore = chunkMeta.dataset.hasMore === "true";
                    const nextSkip = chunkMeta.dataset.nextSkip || skip;

                    loadMoreBtn.dataset.skip = nextSkip;

                    if (!hasMore) {
                        loadMoreBtn.remove();
                    } else {
                        loadMoreBtn.disabled = false;
                        loadMoreBtn.textContent = "Завантажити ще";
                    }
                } catch {
                    loadMoreBtn.disabled = false;
                    loadMoreBtn.textContent = "Завантажити ще";
                } finally {
                    loading = false;
                }
                });

                if ("IntersectionObserver" in window) {
                    const sentinel = document.getElementById("loadMoreSentinel");
                    const observer = new IntersectionObserver(function (entries) {
                        if (entries.some(function (entry) { return entry.isIntersecting; }) && document.body.contains(loadMoreBtn)) {
                            loadMoreBtn.click();
                        }
                    }, { rootMargin: "320px 0px" });

                    if (sentinel) observer.observe(sentinel);
                }
            }

            document.querySelectorAll(".ph-modal-choice-chip input").forEach(function (input) {
                input.addEventListener("change", function () {
                    if (input.type === "radio") {
                        document.querySelectorAll("input[name='" + input.name + "']").forEach(function (radio) {
                            radio.closest(".ph-modal-choice-chip")?.classList.toggle("ph-modal-choice-chip-selected", radio.checked);
                        });
                    } else {
                        input.closest(".ph-modal-choice-chip")?.classList.toggle("ph-modal-choice-chip-selected", input.checked);
                    }
                });
            });

        })();
    </script>
}



